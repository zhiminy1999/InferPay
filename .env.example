# Deployer credentials for backing server-side swaps and sponsorships (Circle Gas Station simulation)
DEPLOYER_PRIVATE_KEY=your_private_key_here

# Circle Web3 Services Credentials
CIRCLE_API_KEY=
CIRCLE_KIT_KEY=
NEXT_PUBLIC_CIRCLE_CLIENT_KEY=
NEXT_PUBLIC_CIRCLE_CLIENT_URL=https://api.circle.com/v1/w3s

# Supabase Configurations (Optional cloud database integration)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# WalletConnect & RainbowKit Configurations
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Blockchain Configurations
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_ENVIRONMENT=development
